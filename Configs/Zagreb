 exec-timeout 0 30
exit
login block-for 300 attempts 3 within 120
banner motd #
AVISO: Acesso restrito a utilizadores autorizados. Todas as ligacoes sao monitorizadas e registadas. Qualquer tentativa de acesso nao autorizado sera reportada as autoridades competentes.
#

ip host RT1-Zg 172.20.7.97
ip host MLS1-Zg 172.20.7.98
ip host MLS2-Zg 172.20.7.102
ip host SW1-Zg 172.20.7.4
ip host SW2-Zg 172.20.7.5

sdm prefer dual-ipv4-and-ipv6 default
end
write memory
reload

enable
configure terminal

vlan 5
 name APs
vlan 6
 name MANAGEMENT
vlan 7
 name NATIVE
vlan 10
 name SERVERS
vlan 20
 name ADMINISTRATION
vlan 30
 name STAFF
vlan 40
 name VOIP
vlan 50
 name WIRELESS
vlan 60
 name GUESTS
vlan 99
 name BLACKHOLE
exit

interface range FastEthernet0/1-10
 switchport mode access
 switchport access vlan 20
 switchport voice vlan 40
 switchport nonegotiate
exit

interface range FastEthernet0/11-20
 switchport mode access
 switchport access vlan 30
 switchport voice vlan 40
 switchport nonegotiate
exit

interface range FastEthernet0/21-22
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk native vlan 5
 switchport trunk allowed vlan 5,50,60
 switchport nonegotiate
exit

interface FastEthernet0/23
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk native vlan 6
 switchport trunk allowed vlan 5,6,50,60
 switchport nonegotiate
exit

interface GigabitEthernet0/1
 description Trunk to MLS1-Zg
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk native vlan 7
 switchport trunk allowed vlan except 99
 switchport nonegotiate
exit

interface GigabitEthernet0/2
 description Trunk to MLS2-Zg
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk native vlan 7
 switchport trunk allowed vlan except 99
 switchport nonegotiate
exit

interface FastEthernet0/24
 switchport mode access
 switchport access vlan 99
 switchport nonegotiate
 shutdown
exit

interface Vlan6
 description Management SVI
 ip address 172.20.7.5 255.255.255.224
 ipv6 address 2001:A:0:5::5/64
 ipv6 address FE80::2:1 link-local
 no shutdown
exit

ip default-gateway 172.20.7.3
ipv6 route ::/0 Vlan6 FE80::1:6

spanning-tree mode rapid-pvst
spanning-tree portfast default

ip dhcp snooping
ip dhcp snooping vlan 20,30,40,50,60

interface range GigabitEthernet0/1-2
 ip dhcp snooping trust
 ip arp inspection trust
 spanning-tree portfast disable
exit

interface range FastEthernet0/21-23
 ip dhcp snooping trust
 spanning-tree portfast disable
exit

interface range FastEthernet0/1-20
 switchport port-security
 switchport port-security maximum 5
 switchport port-security violation shutdown
 switchport port-security aging time 5
 switchport port-security aging type inactivity
 ip dhcp snooping limit rate 5
 spanning-tree bpduguard enable
 ip arp inspection limit rate 5
exit

ip arp inspection vlan 20,30

end
write memory
