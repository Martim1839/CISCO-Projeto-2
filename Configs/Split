# Parte 7 - Adjust STP Default Configuration (Switch)
###Switch(SW1-St)

enable
configure terminal
spanning-tree mode rapid-pvst
end
copy running-config startup-config

-confirmar
show spanning-tree summary

#Parte 10 - Perform Security Configurations (Switch)

###Switch(SW1-St)

#### a. Verificar se as portas não usadas estão em shutdown na Parte 5

show interfaces status | include disabled

#### b. Port security nas portas de acesso Vlan 30 que é o que tem porta de acesso real

- Vlan 30

enable
configure terminal
interface range FastEthernet0/2 - 15
 switchport port-security
 switchport port-security maximum 5
 switchport port-security violation shutdown
 switchport port-security aging time 5
 switchport port-security aging type inactivity
exit

#### c. DHCP Snooping

ip dhcp snooping
ip dhcp snooping vlan 30,50,60
interface FastEthernet0/1
 ip dhcp snooping trust
exit
interface range FastEthernet0/2 - 15
 ip dhcp snooping limit rate 5
exit
interface range FastEthernet0/21 - 22
 ip dhcp snooping limit rate 5
exit

#### d. Dynamic ARP Inspection (vlan 30)

ip arp inspection vlan 30
interface FastEthernet0/1
 ip arp inspection trust
exit
interface range FastEthernet0/2 - 15
 ip arp inspection limit rate 5
exit

#### e. PortFast
interface range FastEthernet0/2 - 15
spanning-tree portfast
exit


#### f.BPDU Guard

interface range FastEthernet0/2 - 15
 spanning-tree bpduguard enable
exit

- Gravar
end
copy running-config startup-config

- Verificar
show port-security interface FastEthernet0/2
show ip dhcp snooping
show ip arp inspection vlan 30
show spanning-tree interface FastEthernet0/2 detail
show spanning-tree summary
show running-config interface FastEthernet0/2



#Parte 11 - Configure Static Routes (Router)

#### a.  Rotas entre localidades (RT1-St)

enable
configure terminal

! IPv4 — para Zagreb (direta + backup via Pula)
ip route 172.20.0.0 255.255.248.0 10.0.0.5
ip route 172.20.0.0 255.255.248.0 10.0.0.9 200

! IPv4 — para Pula (direta + backup via Zagreb)
ip route 172.20.8.0 255.255.252.0 10.0.0.9
ip route 172.20.8.0 255.255.252.0 10.0.0.5 200

! IPv6 — para Zagreb e Pula (next-hop = vizinho, sufixo próprio do vizinho)
ipv6 route 2001:A::/61 GigabitEthernet0/2.103 FE80::103ZG
ipv6 route 2001:A::/61 GigabitEthernet0/2.203 FE80::203PL 200
ipv6 route 2001:B::/61 GigabitEthernet0/2.203 FE80::203PL
ipv6 route 2001:B::/61 GigabitEthernet0/2.103 FE80::103ZG 200

- Guardar
end
copy running-config startup-config


